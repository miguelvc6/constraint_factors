{
  "model_config": {
    "constraint_representation": "factorized",
    "dataset_variant": "full_minocc100",
    "enable_policy_choice": false,
    "encoding": "node_id",
    "factor_executor_impl": "per_type_v1",
    "min_occurrence": 100,
    "model": "GIN_PRESSURE",
    "num_factor_types": 29,
    "policy_num_classes": 6,
    "pressure_enabled": true,
    "pressure_residual_scale": 0.1,
    "pressure_type_conditioning": "concat",
    "role_embedding_dim": 16,
    "use_edge_attributes": true,
    "use_edge_subtraction": false,
    "use_role_embeddings": true
  },
  "training_config": {
    "batch_size": 256,
    "chooser": {
      "beta_no_regression": 0.5,
      "enabled": false,
      "gamma_primary": 1.0,
      "loss_mode": "fix1",
      "loss_weight": 0.5,
      "max_candidates_total": 80,
      "topk_candidates": 20
    },
    "constraint_loss": {
      "dynamic_reweighting": {
        "enabled": true
      }
    },
    "direct_safety": {
      "alpha_primary": 1.0,
      "beta_secondary": 0.5,
      "enabled": true,
      "max_candidates_total": 80,
      "topk_candidates": 20
    },
    "early_stopping_rounds": 5,
    "factor_loss": {
      "enabled": true,
      "weight_post_gold": 0.1,
      "weight_pre": 0.1
    },
    "fix_probability_loss": {
      "enabled": false
    },
    "learning_rate": 0.0003,
    "num_epochs": 20,
    "num_workers": 2,
    "pin_memory": false,
    "policy_filter_strict": true,
    "scheduler_factor": 0.5,
    "scheduler_patience": 1,
    "validate_factor_labels": true,
    "validation_subset_size": 25000,
    "weight_decay": 0.0001
  }
}
