{
  "model_config": {
    "dataset_variant": "full_minocc100",
    "dropout": 0.17,
    "encoding": "node_id",
    "factor_executor_impl": "per_type_v1",
    "head_hidden": 400,
    "hidden_channels": 400,
    "min_occurrence": 100,
    "model": "GIN_PRESSURE",
    "num_factor_types": 29,
    "num_layers": 4,
    "num_role_types": 6,
    "pressure_enabled": true,
    "pressure_residual_scale": 0.1,
    "pressure_type_conditioning": "concat",
    "role_embedding_dim": 16,
    "use_edge_attributes": true,
    "use_edge_subtraction": false,
    "use_node_embeddings": false,
    "use_role_embeddings": true
  },
  "training_config": {
    "batch_size": 256,
    "chooser": {
      "beta_no_regression": 2.0,
      "enabled": true,
      "gamma_primary": 0.0,
      "loss_mode": "fix1",
      "loss_weight": 0.5,
      "max_candidates_total": 80,
      "topk_candidates": 20
    },
    "early_stopping_rounds": 5,
    "factor_loss": {
      "enabled": true,
      "only_checkable": true,
      "per_graph_reduction": "mean",
      "weight_post_gold": 0.1,
      "weight_pre": 0.1
    },
    "fix_probability_loss": {
      "enabled": false
    },
    "learning_rate": 0.0003,
    "num_epochs": 20,
    "num_workers": 2,
    "pin_memory": false,
    "policy_filter_strict": true,
    "scheduler_factor": 0.5,
    "scheduler_patience": 1,
    "validate_factor_labels": true,
    "validation_subset_size": 25000,
    "weight_decay": 0.00011
  }
}
